---
import avatarHeaderFallback from "../assets/avatar-portrait.png";
import avatarVideoMp4 from "../assets/avatar-portrait-140.mp4";
import ThemeToggle from "../components/ThemeToggle.tsx";
export interface Props {
  title?: string;
  currentPage?: string;
  preloadImages?: Array<{ src: string }>;
}

const {
  title = "Mark Wylde - Personal Portfolio",
  currentPage = "home",
  preloadImages = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{preloadImages.map((image) => <link rel="preload" as="image" href={image.src} />)}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
		<script is:inline>
			(function() {
				const savedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = savedTheme || (prefersDark ? 'dark' : 'light');
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
	</head>
	<body>
		<div class="site-header">
			<div class="container site-header-content">
				<div class="header-left">
					<a href="/" class="header-avatar-link">
						<video autoplay muted class="header-avatar" playsinline poster={avatarHeaderFallback.src} width="75" height="75">
							<source src={avatarVideoMp4} type="video/mp4" />
							<img src={avatarHeaderFallback.src} alt="Mark Wylde - Avatar" />
						</video>
					</a>
					<a href="/" class="header-site-title">Mark Wylde</a>
				</div>
				<div class="header-right">
					<nav class="main-nav">
						<a href="/" class={`nav-link ${currentPage === 'home' ? 'nav-link-active' : ''}`}>Home</a>
						<a href="/about" class={`nav-link ${currentPage === 'about' ? 'nav-link-active' : ''}`}>About</a>
						<a href="/blog" class={`nav-link ${currentPage === 'blog' ? 'nav-link-active' : ''}`}>Blog</a>
					</nav>
					<ThemeToggle client:load />
				</div>
			</div>
		</div>
		<main>
			<slot />
		</main>
		<footer class="footer">
			<div class="container">
				<p>&copy; <span id="currentYear"></span> Mark Wylde. All Rights Reserved.</p>
			</div>
		</footer>
		<script>
			const currentYearElement = document.getElementById('currentYear');
			if (currentYearElement) {
				currentYearElement.textContent = new Date().getFullYear().toString();
			}

			const siteHeader = document.querySelector('.site-header');
			const headerAvatar = document.querySelector('.header-avatar');

			if (siteHeader && headerAvatar) {
				let currentTimeUpdateListener = null;

				function playToMidpoint() {
					// Remove any existing listener to prevent conflicts
					if (currentTimeUpdateListener) {
						headerAvatar.removeEventListener('timeupdate', currentTimeUpdateListener);
					}

					headerAvatar.currentTime = 0;
					headerAvatar.play();

					currentTimeUpdateListener = () => {
						if (headerAvatar.currentTime >= headerAvatar.duration * 0.5) {
							headerAvatar.pause();
							headerAvatar.removeEventListener('timeupdate', currentTimeUpdateListener);
							currentTimeUpdateListener = null;
						}
					};

					headerAvatar.addEventListener('timeupdate', currentTimeUpdateListener);
				}

				function playFromMidpoint() {
					// Remove any existing listener to prevent interference
					if (currentTimeUpdateListener) {
						headerAvatar.removeEventListener('timeupdate', currentTimeUpdateListener);
						currentTimeUpdateListener = null;
					}

					headerAvatar.currentTime = headerAvatar.duration * 0.5;
					headerAvatar.play();
				}

				siteHeader.addEventListener('mouseenter', playToMidpoint);
				siteHeader.addEventListener('mouseleave', playFromMidpoint);
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--primary-bg: #e8ebf2;      /* page */
		--secondary-bg: #ffffff;    /* content cards, header */
		--surface-2: #f1f4fa;       /* bands, code, chips — subtle, distinct from card */
		--text-color: #475067;
		--heading-color: #111827;
		--muted-color: #6b7488;
		--accent-color: #4f46e5;
		--accent-fill: #4f46e5;
		--accent-fill-hover: #4338ca;
		--on-accent: #ffffff;
		--header-bg: #ffffff;
		--border-color: #e4e7ef;
		--shadow-color: rgba(17, 24, 39, 0.07);
		--hero-bg: #eef1f8;
		--avatar-bg: #f1f4fa;
		--container-padding: 20px;
	}

	[data-theme="dark"] {
		--primary-bg: #0b1120;      /* page */
		--secondary-bg: #141d31;    /* content cards, header */
		--surface-2: #0e1626;       /* bands, code, chips — recessed, distinct from card */
		--text-color: #c3cee0;
		--heading-color: #f3f6fb;
		--muted-color: #8d9ab2;
		--accent-color: #818cf8;
		--accent-fill: #4f46e5;
		--accent-fill-hover: #5b52ec;
		--on-accent: #ffffff;
		--header-bg: #101a2e;
		--border-color: #243049;
		--shadow-color: rgba(0, 0, 0, 0.45);
		--hero-bg: #0e1626;
		--avatar-bg: #18233a;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Montserrat', sans-serif;
		line-height: 1.7;
		color: var(--text-color);
		background-color: var(--primary-bg);
		font-weight: 300;
	}

	.container {
		width: 100%;
		max-width: 1400px;
		margin: auto;
		padding: 0 var(--container-padding);
		overflow: hidden;
	}

	h1, h2, h3 {
		color: var(--heading-color);
		font-weight: 600;
		margin-bottom: 0.75em;
	}

	h1 { font-size: 3em; }
	h2 { font-size: 2.2em; }
	h3 { font-size: 1.5em; }

	p {
		margin-bottom: 1em;
	}

	a {
		color: var(--accent-color);
		text-decoration: none;
		transition: color 0.3s ease;
	}

	a:hover {
		color: var(--heading-color);
	}

	.site-header {
		background-color: var(--header-bg);
		padding: 15px 0;
		border-bottom: 1px solid var(--border-color);
		box-shadow: 0 2px 4px var(--shadow-color);
	}

	.site-header-content {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.header-left {
		display: flex;
		align-items: center;
	}

	.header-avatar-link {
		display: block;
		margin-right: 15px;
	}

	.header-avatar {
		height: 75px;
		width: 75px;
		border-radius: 50%;
		object-fit: cover;
	}

	.header-site-title {
		font-size: 1.5em;
		font-weight: 600;
		color: var(--heading-color);
	}

	.header-right {
		display: flex;
		align-items: center;
		gap: 15px;
	}

	.main-nav {
		display: flex;
		gap: 20px;
		align-items: center;
	}

	.nav-link {
		color: var(--text-color);
		text-decoration: none;
		font-weight: 400;
		padding: 8px 12px;
		border-radius: 4px;
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	.nav-link:hover {
		background-color: var(--primary-bg);
		color: var(--heading-color);
	}

	.nav-link-active {
		background-color: var(--accent-fill);
		color: var(--on-accent);
		font-weight: 500;
	}

	.nav-link-active:hover {
		background-color: var(--accent-fill-hover);
		color: var(--on-accent);
	}

	.section {
		padding: 30px 0;
	}

	.section:nth-child(even) {
		background-color: var(--secondary-bg);
	}

	.footer {
		text-align: center;
		padding: 40px 0;
		background-color: #0f172a;
		color: #f8fafc;
		font-size: 0.9em;
		border-top: 1px solid var(--border-color);
	}

	[data-theme="dark"] .footer {
		background-color: #020617;
		color: #94a3b8;
	}

	.footer p { margin-bottom: 0; }






	/* Project Grid Styles */
	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 30px;
	}

	.project-card {
		background-color: var(--secondary-bg);
		padding: 25px;
		border-radius: 8px;
		box-shadow: 0 5px 15px var(--shadow-color);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		border: 1px solid var(--border-color);
	}

	.project-card:hover {
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
	}

	/* Theme Toggle Styles */
	.theme-toggle {
		background: var(--secondary-bg);
		border: 1px solid var(--border-color);
		border-radius: 8px;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.2s ease;
		color: var(--text-color);
		padding: 0;
	}

	.theme-toggle:hover {
		background-color: var(--primary-bg);
		border-color: var(--accent-color);
		color: var(--accent-color);
		transform: translateY(-1px);
		box-shadow: 0 4px 12px var(--shadow-color);
	}

	.theme-toggle-icon {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* Contact Methods Styles */
	.contact-methods {
		display: flex;
		justify-content: center;
		gap: 20px;
		margin-top: 20px;
		flex-wrap: wrap;
	}

	.contact-methods a {
		font-size: 1.1em;
		padding: 10px 20px;
		border: 1px solid var(--border-color);
		border-radius: 5px;
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	.contact-methods a:hover {
		background-color: var(--accent-fill);
		color: var(--on-accent);
		text-decoration: none;
	}

	/* Shared Blog Styles */
	.blog-meta {
		align-items: center;
	}

	.blog-meta time {
		color: var(--heading-color);
		font-size: 0.9em;
	}

	.blog-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	.tag {
		background-color: var(--surface-2);
		color: var(--text-color);
		padding: 4px 8px;
		border-radius: 4px;
		font-size: 0.8em;
		border: 1px solid var(--border-color);
	}

	/* Fix for markdown callout boxes */
	[data-theme="dark"] div[style*="background: #f8f9fa"],
	[data-theme="dark"] div[style*="background:#f8f9fa"] {
		background-color: var(--secondary-bg) !important;
		border-color: var(--border-color) !important;
	}
	[data-theme="dark"] div[style*="background: #f8f9fa"] a,
	[data-theme="dark"] div[style*="background:#f8f9fa"] a {
		color: var(--accent-color) !important;
	}
	[data-theme="dark"] div[style*="background: #f8f9fa"] p,
	[data-theme="dark"] div[style*="background:#f8f9fa"] p {
		color: var(--text-color) !important;
	}

	@media (max-width: 768px) {
		h1 { font-size: 1.8em; }
		h2 { font-size: 1.4em; }

		.site-header {
			padding: 10px 0;
		}

		.site-header-content {
			flex-direction: column;
			gap: 15px;
		}

		.header-right {
			width: 100%;
			justify-content: center;
			gap: 20px;
		}

		.header-avatar {
			height: 50px;
			width: 50px;
		}

		.header-site-title {
			font-size: 1.2em;
		}

		.main-nav {
			gap: 15px;
		}

		.nav-link {
			font-size: 0.9em;
			padding: 6px 10px;
		}

		.container {
			--container-padding: 10px;
		}

		.section {
			padding: 20px 0;
		}

	}
</style>
